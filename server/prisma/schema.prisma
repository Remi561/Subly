// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(cuid())

  name String 
  username String @unique 
  email String @unique
  password String 

  baseCurrency String
  role Role @default(USER)
  
  subscriptions Subscription[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}



model Subscription {
  id String @id @default(cuid())
  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  name String
  logoUrl String
  category Category @default(OTHER)

  amount Decimal @db.Decimal(12,2)
  currency String
  exchangeRate Decimal @db.Decimal(12,4)
  settledAmount Decimal @db.Decimal(12,2)

  billingCycle BillingCycle @default(MONTHLY)
  status Status @default(ACTIVE)
  nextBillingDate DateTime

  reminderEnabled    Boolean   @default(true)
  reminderDaysBefore Int       @default(3)
  reminderSent       Boolean   @default(false)
  reminderSentAt     DateTime?

  expiredEmailSent   Boolean   @default(false)
  expiredEmailSentAt DateTime?


  histories History[]

  createdAt DateTime @default(now())
  updateAt DateTime @updatedAt


  
  @@index([userId])
  @@index([userId, status])
  @@index([status, nextBillingDate])
  @@unique([userId, name])
}
model History {
  id String @id @default(cuid())

  subscriptionId String
  subscriptionName String
  subscriptionLogoUrl String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  category Category @default(OTHER)

  paidAmount    Decimal @db.Decimal(12, 2)
  paidCurrency  String

  baseCurrency  String
  exchangeRate  Decimal @db.Decimal(12, 4)
  settledAmount Decimal @db.Decimal(12, 2)

  paidAt DateTime @default(now())

  type Type @default(CREATED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subscriptionId])
  @@index([paidAt])

}


model Rates{
  id String @id @default(cuid())
  baseCurrency String @unique
  rates Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
enum Role {
  USER
  ADMIN
}
enum BillingCycle {
  MONTHLY
  WEEKLY
  YEARLY
}

enum Status {
  ACTIVE
  EXPIRED
  CANCELLED
  ARCHIVED
}

enum Category {
  ENTERTAINMENT
  PRODUCTIVITY
  SOFTWARE
  STORAGE
  EDUCATION
  AI_TOOLS
  OTHER
}

enum Type {
  CREATED
  EDITED
  RENEWED

}